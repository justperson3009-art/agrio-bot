# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# ==========================================
# YANDEXGPT API (Yandex Cloud) - ОСНОВНАЯ МОДЕЛЬ
# ==========================================
# Создать сервисный аккаунт: https://console.cloud.yandex.ru/
# IAM → Сервисные аккаунты → Создать ключи

# Key ID сервисного аккаунта (начинается с YCAJ...)
YANDEX_KEY_ID=your_key_id_here

# Secret Key сервисного аккаунта (начинается с YCP...)
YANDEX_SECRET_KEY=your_secret_key_here

# Folder ID каталога (начинается с b1g...)
YANDEX_FOLDER_ID=your_folder_id_here

# ==========================================
# QWEN API (Alibaba Cloud DashScope) - РЕЗЕРВ
# ==========================================
QWEN_API_KEY=

# ==========================================
# QWEN LOCAL (Ollama) - ОТКЛЮЧЕНО ПО УМОЛЧАНИЮ
# ==========================================
QWEN_LOCAL=false
OLLAMA_URL=http://localhost:11434/api/generate
QWEN_MODEL_LOCAL=qwen2.5:7b

# ==========================================
# Администратор бота (Telegram ID)
# ==========================================
ADMIN_ID=your_telegram_user_id

# Разрешённые chat_id для ответов (через запятую) или оставьте пустым для всех чатов
ALLOWED_CHAT_IDS=

# ==========================================
# НАСТРОЙКИ ЧАТОВ (для экономии токенов)
# ==========================================
# ЧАТ 1: Бот отвечает ТОЛЬКО по упоминанию @bot
# Укажите chat_id чата/группы где бот работает по упоминанию
CHAT_MENTION_ONLY=0

# ЧАТ 2: Бот отвечает НА ВСЕ сообщения (режим агронома)
# Укажите chat_id чата где бот отвечает автоматически на все вопросы
CHAT_AGRO_MODE=0

# ==========================================
# Как узнать chat_id:
# 1. Добавьте бота @getmyid_bot
# 2. Напишите ему любое сообщение
# 3. Он покажет ваш ID и ID чата
# 4. Скопируйте ID в этот файл
# ==========================================
