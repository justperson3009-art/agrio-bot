# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# ==========================================
# QWEN API (Alibaba Cloud DashScope) - ОБЛАКО
# ==========================================
# Получить API ключ: https://dashscope.console.aliyun.com/
# Закомментируйте если используете локальную модель

# Qwen API Key
QWEN_API_KEY=sk-your_qwen_api_key_here

# Модель Qwen (qwen-plus, qwen-turbo, qwen-max)
QWEN_MODEL=qwen-plus

# ==========================================
# QWEN LOCAL (Ollama) - ЛОКАЛЬНО НА СЕРВЕРЕ
# ==========================================
# Бесплатно, без лимитов, данные у вас
# Установите Ollama: curl -fsSL https://ollama.com/install.sh | sh

# true = использовать локальную модель (требуется Ollama)
# false = использовать облако (требуется QWEN_API_KEY)
QWEN_LOCAL=false

# URL локального Ollama
OLLAMA_URL=http://localhost:11434/api/generate

# Локальная модель (qwen2.5:7b, qwen2.5:14b, qwen2.5:32b)
# 7b = для 8GB RAM, 14b = для 16GB RAM, 32b = для 32GB+ RAM
QWEN_MODEL=qwen2.5:7b

# ==========================================
# Администратор бота (Telegram ID)
# ==========================================
ADMIN_ID=your_telegram_user_id

# Разрешённые chat_id для ответов (через запятую) или оставьте пустым для всех чатов
ALLOWED_CHAT_IDS=

# ==========================================
# НАСТРОЙКИ ЧАТОВ (для экономии токенов)
# ==========================================
# ЧАТ 1: Бот отвечает ТОЛЬКО по упоминанию @bot
# Укажите chat_id чата/группы где бот работает по упоминанию
CHAT_MENTION_ONLY=0

# ЧАТ 2: Бот отвечает НА ВСЕ сообщения (режим агронома)
# Укажите chat_id чата где бот отвечает автоматически на все вопросы
CHAT_AGRO_MODE=0

# ==========================================
# Как узнать chat_id:
# 1. Добавьте бота @getmyid_bot
# 2. Напишите ему любое сообщение
# 3. Он покажет ваш ID и ID чата
# 4. Скопируйте ID в этот файл
# ==========================================
